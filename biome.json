{
	"$schema": "node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master"
	},
	"files": {
		"includes": ["**", "!!**/dist"]
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"rules": {
			"complexity": { "recommended": true },
			"correctness": { "recommended": true },
			"nursery": { "recommended": true },
			"security": { "recommended": true },
			"style": { "recommended": true },
			"suspicious": { "recommended": true }
		},
		"domains": {
			"project": "recommended",
			"test": "recommended",
			"types": "recommended"
		}
	},
	"javascript": {
		"assist": { "enabled": true },
		"linter": { "enabled": true }
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	}
}
