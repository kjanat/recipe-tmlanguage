{
	"name": "recipe-tmlanguage",
	"version": "0.1.0",
	"description": "TextMate grammar for the recipe (.recipe) pharmacological notation language.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/recipe-tmlanguage.git"
	},
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"type": "module",
	"exports": {
		".": "./dist/recipe.tmLanguage.json",
		"./dist/*": "./dist/*",
		"./package.json": "./package.json"
	},
	"main": "./dist/recipe.tmLanguage.json",
	"module": "./dist/recipe.tmLanguage.json",
	"bin": {
		"recipe-tmlang": "./cli.ts"
	},
	"files": [
		"cli.ts",
		"src/**",
		"dist/**",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"cli": "bun cli.ts",
		"fmt": "dprint fmt",
		"generate": "bun cli.ts generate",
		"prepack": "bun generate",
		"typecheck": "tsc --noEmit",
		"verify": "bun cli.ts verify"
	},
	"dependencies": {
		"@kjanat/dreamcli": "^2.1.0",
		"tree-sitter-recipe": "link:tree-sitter-recipe",
		"vscode-oniguruma": "^2.0.1",
		"vscode-textmate": "^9.2.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.12",
		"dprint": "^0.54.0",
		"typescript": "^6.0.3"
	},
	"packageManager": "bun@1.3.13",
	"trustedDependencies": [
		"tree-sitter-recipe"
	]
}
