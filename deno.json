{
	"name": "@kjanat/recipe-tmlanguage",
	"version": "0.3.4",
	"license": "MIT",
	"exports": {
		".": "./recipe.tmLanguage.ts",
		"./bin": "./bin/recipe-tmlang.ts"
	},
	"tasks": {
		"check": "deno check",
		"lint": "deno lint",
		"version": "deno run -A ./bin/recipe-tmlang.mjs --version",
		"ci": {
			"command": "echo 'all gucci'",
			"dependencies": ["check", "lint", "version"]
		}
	},
	"imports": {
		"@kjanat/dreamcli": "jsr:@kjanat/dreamcli@^2.4.1",
		"tree-sitter-recipe": "jsr:@kjanat/tree-sitter-recipe@^0.3.1",
		"tree-sitter-recipe/": "jsr:@kjanat/tree-sitter-recipe@^0.3.1/"
	},
	"publish": {
		"include": [
			"recipe.tmLanguage.ts",
			"recipe.tmLanguage.json",
			"bin/recipe-tmlang.ts",
			"bin/commands/generate.ts",
			"bin/commands/verify.ts",
			"src/grammar.ts",
			"src/verifier.ts",
			"package.json",
			"LICENSE",
			"README.md",
			"deno.json"
		]
	},
	"nodeModulesDir": "none"
}
